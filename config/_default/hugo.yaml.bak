baseURL: "https://iris-rs-lab.github.io/site/"
title: "IRIS | Intelligent Remote-sensing Information Systems & Applications"
defaultContentLanguage: zh
defaultContentLanguageInSubdir: true

languages:
  zh:
    languageName: "中文"
    weight: 1
    contentDir: "content/zh"
    title: "智能遥感信息工程与应用课题组（IRIS）"
    params:
      description: "智能遥感信息工程与应用课题组（IRIS）"
  en:
    languageName: "English"
    weight: 2
    contentDir: "content/en"
    title: "IRIS | Intelligent Remote-sensing Information Systems & Applications"
    params:
      description: "Intelligent Remote-sensing Information Systems & Applications (IRIS)"

# taxonomies（可用于标签/类别过滤）
taxonomies:
  tag: tags
  category: categories

# 输出（搜索、RSS 等按需）
outputs:
  home: ["HTML", "RSS", "JSON"]
  section: ["HTML", "RSS"]
  taxonomy: ["HTML", "RSS"]
  term: ["HTML", "RSS"]

caches:
  images:
    dir: :cacheDir/images

security:
  funcs:
    getenv:
      - "^HUGO_"
      - "^CI$"
      - "^WC_"

module:
  imports:
    - path: github.com/HugoBlox/hugo-blox-builder/modules/blox-bootstrap/v5
