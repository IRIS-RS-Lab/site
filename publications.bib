@article{zhangStudyGlobalBurned2020,
  title = {Study on {{Global Burned Forest Areas Based}} on {{Landsat Data}}},
  author = {Zhang, Zhaoming and Long, Tengfei and He, Guojin and Wei, Mingyue and Tang, Chao and Wang, Wei and Wang, Guizhou and She, Wenqing and Zhang, Xiaomei},
  year = 2020,
