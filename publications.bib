@article{weiRelativeRadiationNormalization2020,
  title = {A {{Relative Radiation Normalization Method}} of {{ISS Nighttime Light Images Based}} on {{Pseudo Invariant Features}}},
  author = {Wei, Shengrong and Jiao, Weili and Long, Tengfei and Liu, Huichan and Bi, Lu and Jiang, Wei and Portnov, Boris A. and Liu, Ming},
