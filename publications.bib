@article{chenTIRVisibleAutomaticRegistration2022,
  title = {A {{TIR-Visible Automatic Registration}} and {{Geometric Correction Method}} for {{SDGSAT-1 Thermal Infrared Image Based}} on {{Modified RIFT}}},
  author = {Chen, Jinfen and Cheng, Bo and Zhang, Xiaoping and Long, Tengfei and Chen, Bo and Wang, Guizhou and Zhang, Degang},
