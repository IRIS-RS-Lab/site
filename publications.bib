@article{wangAssessmentEconomicWellbeing2025,
  title = {Assessment of Economic Well-Being in South Africa Based on Remote Sensing Transfer Learning},
  author = {Wang, Longfei and Long, Tengfei and Adam, Elhadi},
  year = 2025,
  month = may,
  journal = {The International Archives of the Photogrammetry, Remote Sensing and Spatial Information Sciences},
  volume = {XLVIII-M-7-2025},
  pages = {253--258},
