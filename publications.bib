@article{fanSentinel2ImagesBased2022,
  title = {Sentinel-2 {{Images Based Modeling}} of {{Grassland Above-Ground Biomass Using Random Forest Algorithm}}: {{A Case Study}} on the {{Tibetan Plateau}}},
  shorttitle = {Sentinel-2 {{Images Based Modeling}} of {{Grassland Above-Ground Biomass Using Random Forest Algorithm}}},
  author = {Fan, Xinyue and He, Guojin and Zhang, Wenyi and Long, Tengfei and Zhang, Xiaomei and Wang, Guizhou and Sun, Geng and Zhou, Huakun and Shang, Zhanhuan and Tian, Dashuan and Li, Xiangyi and Song, Xiaoning},
  year = 2022,
